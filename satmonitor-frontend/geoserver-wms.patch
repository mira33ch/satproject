+export class SatMapComponent implements AfterViewInit, OnDestroy {
+  @ViewChild('mapEl', { static: true }) mapEl!: ElementRef<HTMLDivElement>;
   @Input() centerLonLat: [number, number] = [-17.44406, 14.6937]; // Dakar
   @Input() zoom = 11;
 
   private map?: Map;
+  private wmsLayer?: TileLayer<TileWMS>;
+  private wmsSource?: TileWMS;
+  private featureInfoKey?: EventsKey;
+  private capabilitiesDocPromise?: Promise<Document | null>;
+
+  readonly availableLayers: SatmonitorWmsLayerOption[] = [
+    {
+      id: 'deforestation_ndvi_date1',
+      label: 'NDVI (date 1)',
+      layerName: 'satmonitor:deforestation_ndvi_date1',
+      styleName: 'ndvi',
+    },
+    {
+      id: 'deforestation_ndvi_date2',
+      label: 'NDVI (date 2)',
+      layerName: 'satmonitor:deforestation_ndvi_date2',
+      styleName: 'ndvi',
+    },
+    {
+      id: 'deforestation_ndmi_date1',
+      label: 'NDMI (date 1)',
+      layerName: 'satmonitor:deforestation_ndmi_date1',
+      styleName: 'ndmi',
+    },
+    {
+      id: 'deforestation_ndmi_date2',
+      label: 'NDMI (date 2)',
+      layerName: 'satmonitor:deforestation_ndmi_date2',
+      styleName: 'ndmi',
+    },
+    {
+      id: 'deforestation_delta_ndvi',
+      label: 'Δ NDVI',
+      layerName: 'satmonitor:deforestation_delta_ndvi',
+      styleName: 'delta_ndvi',
+    },
+    {
+      id: 'deforestation_delta_ndmi',
+      label: 'Δ NDMI',
+      layerName: 'satmonitor:deforestation_delta_ndmi',
+      styleName: 'delta_ndmi',
+    },

   ngAfterViewInit(): void {
+    const selected = this.selectedLayer;
+    if (!selected) return;
+
+    this.wmsSource = new TileWMS({
+      url: this.wmsUrl,
+      projection: 'EPSG:3857',
+      params: {
+        SERVICE: 'WMS',
+        VERSION: '1.1.0',
+        LAYERS: selected.layerName,
+        STYLES: selected.styleName,
+        FORMAT: 'image/png',
+        TRANSPARENT: true,
+        TILED: true,
+        SRS: 'EPSG:3857',
+      },
+      serverType: 'geoserver',

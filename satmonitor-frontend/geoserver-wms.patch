         center: fromLonLat(this.centerLonLat),
         zoom: this.zoom
       })
     });
+
+    this.featureInfoKey = this.map.on('singleclick', (evt) => {
+      if (!this.map || !this.wmsSource || !this.wmsLayer?.getVisible()) return;
+
+      const view = this.map.getView();
+      const resolution = view.getResolution();
+      const projection = view.getProjection();
+      const selectedLayer = this.selectedLayer;
+      if (!resolution || !selectedLayer) return;
+
+      const url = this.wmsSource.getFeatureInfoUrl(evt.coordinate, resolution, projection, {
+        INFO_FORMAT: 'application/json',
+        QUERY_LAYERS: selectedLayer.layerName,
+        FEATURE_COUNT: 10,
+        _t: Date.now(),
+      });
+      if (!url) return;
+
+      const [lon, lat] = toLonLat(evt.coordinate, projection);
+      this.lastFeatureInfo = `Loading… (${lon.toFixed(5)}, ${lat.toFixed(5)})`;
+
+      this.http.get<any>(url).subscribe({
+        next: (data) => {
+          const value = this.extractRasterValue(data);
+          this.lastFeatureInfo =
+            value !== undefined ? `${value} (${lon.toFixed(5)}, ${lat.toFixed(5)})` : `No data (${lon.toFixed(5)}, ${lat.toFixed(5)})`;
+          // Keep a debug trail without impacting the UI
+          // eslint-disable-next-line no-console
+          console.log('GetFeatureInfo', { url, data });
+        },
+        error: (err) => {
+          this.lastFeatureInfo = `GetFeatureInfo error (${lon.toFixed(5)}, ${lat.toFixed(5)})`;
+          // eslint-disable-next-line no-console

+
+  selectedLayerId = this.availableLayers[0]?.id ?? '';
+  wmsVisible = true;
+  wmsOpacity = 0.8; // 0.6–0.9 per requirements
+  lastFeatureInfo?: string;
+
+  constructor(private http: HttpClient) {}
+
+  private get wmsUrl(): string {
+    return `${environment.geoserverBase}/${environment.geoserverWorkspace}/wms`;
+  }
+
+  get selectedLayer(): SatmonitorWmsLayerOption | undefined {
+    return this.availableLayers.find((l) => l.id === this.selectedLayerId);
